    {
      "id": "bug-014",
      "timestamp": "2026-06-18T13:15:00.000Z",
      "error_message": "_duckdb.ConstraintException: Violates foreign key constraint because key 'symbol_id: 3' is still referenced by a foreign key in a different table — on UPDATE symbols SET is_main=...",
      "file": "data_center/collectors/futures_collector.py",
      "root_cause": "DuckDB 1.5.4 禁止 UPDATE 任何被外键引用的行 (kline.symbol_id REFERENCES symbols)，即使不改键列、即使值不变也报错。mark_main_contract 用 UPDATE symbols SET is_main 因此必失败。纯内存表复现不出，真实库 (有 kline 引用 + idx_sym_main 索引) 才触发。",
      "fix": "改用独立表 main_contracts(product_id, symbol_code) 存主力关系，避开对被引用 symbols 表的 UPDATE。枚举接口 /contracts/discover 仍实时返回主力，前端不依赖 symbols.is_main。mark_main_contract 改为 upsert main_contracts，且失败不中断采集主流程。",
      "tags": [
        "duckdb",
        "foreign-key",
        "update-limitation",
        "main-contract",
        "collector"
      ],
      "related_bugs": [],
      "occurrences": 1,
      "last_seen": "2026-06-18T13:15:00.000Z"
    },
