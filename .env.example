# 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 运行环境
ENV=development  # development / staging / production

# 调试模式
DEBUG=True

# 密钥（生产环境请修改）
SECRET_KEY=your-secret-key-change-in-production

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=trading
DB_PASS=trading_pass
DB_NAME=trading_strategy_center

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 缓存配置
LRU_CACHE_SIZE=1000
REDIS_CACHE_TTL=300

# 交易配置
INITIAL_CAPITAL=1000000.0
MAX_POSITION_SIZE=100
MAX_DRAWDOWN_PCT=0.15
MAX_LEVERAGE=3.0

# CORS配置
CORS_ORIGINS=*  # 生产环境请设置具体域名

# LLM API配置（可选）
# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Claude
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-opus-20240229

# 默认LLM提供商
DEFAULT_LLM_PROVIDER=deepseek  # deepseek / openai / claude

# 数据源API密钥（可选）
# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# EIA (能源数据)
EIA_API_KEY=your-eia-key

# FRED (宏观数据)
FRED_API_KEY=your-fred-key

# Tushare Pro (中国股票/期货/期权/财报, 需注册 token)
# 留空则不启用 tushare 数据源
TUSHARE_TOKEN=

# TqSdk 天勤 (期货 tick/主力连续, 需注册账户)
# 留空则不启用 tqsdk 数据源
TQ_ACCOUNT=
TQ_PASSWORD=

# 说明: akshare / baostock / 通达信(easy_tdx) 三个免费源无需任何密钥, 默认启用

# 日志配置
LOG_LEVEL=INFO  # DEBUG / INFO / WARNING / ERROR
LOG_FILE=logs/app.log

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=4

# 前端配置
FRONTEND_URL=http://localhost:3000
